<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ═══════════════════════════════════════════════════════════════════════════════
         PFLICHT-PERMISSIONS
         ═══════════════════════════════════════════════════════════════════════════════ -->
    
    <!-- Netzwerk-Zugriff für Streaming -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    
    <!-- Foreground Service für Media-Playback -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    
    <!-- Boot-Receiver für Autostart -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    
    <!-- Storage für lokale M3U-Dateien (API <= 32) -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    
    <!-- Media für API >= 33 -->
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />

    <!-- ═══════════════════════════════════════════════════════════════════════════════
         FEATURE-DECLARATIONS (Android TV Support)
         ═══════════════════════════════════════════════════════════════════════════════ -->
    
    <!-- Leanback Support (optional für Mobile-Kompatibilität) -->
    <uses-feature
        android:name="android.software.leanback"
        android:required="false" />
    
    <!-- Touchscreen nicht erforderlich (TV-Fernbedienung) -->
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />

    <!-- ═══════════════════════════════════════════════════════════════════════════════
         APPLICATION
         ═══════════════════════════════════════════════════════════════════════════════ -->
    
    <application
        android:name=".DjouDjousIptvApplication"
        android:allowBackup="true"
        android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsPictureInPicture="true"
        android:theme="@style/Theme.DjouDjousIPTV"
        tools:targetApi="34">

        <!-- ═══════════════════════════════════════════════════════════════════════════
             MAIN ACTIVITY (Leanback Launcher)
             ═══════════════════════════════════════════════════════════════════════════ -->
        
        <activity
            android:name=".ui.main.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.DjouDjousIPTV">
            
            <!-- Leanback Launcher Intent -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
            
            <!-- Standard Launcher Intent (für Mobile) -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ═══════════════════════════════════════════════════════════════════════════
             ONBOARDING ACTIVITY
             ═══════════════════════════════════════════════════════════════════════════ -->
        
        <activity
            android:name=".ui.onboarding.OnboardingActivity"
            android:exported="false"
            android:theme="@style/Theme.DjouDjousIPTV" />

        <!-- ═══════════════════════════════════════════════════════════════════════════
             PLAYBACK SERVICE (Media3 MediaSessionService)
             Wird in Phase 4 hinzugefügt
             ═══════════════════════════════════════════════════════════════════════════ -->

        <!-- ═══════════════════════════════════════════════════════════════════════════
             BOOT RECEIVER (Autostart)
             Wird in Phase 6 hinzugefügt
             ═══════════════════════════════════════════════════════════════════════════ -->

    </application>

</manifest>
